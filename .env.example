# DecideAI HR Helper System - Environment Configuration

# Basic settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=postgresql://decideai_user:decideai_pass@localhost:5432/decideai_hr_system

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Models
AI_MODELS_PATH=./ai-engine/models
OCR_MODEL_TIMEOUT=30
LLM_MODEL_TIMEOUT=60

# Processing limits
MAX_FILE_SIZE_MB=50
MAX_CONCURRENT_JOBS=10
PROCESSING_TIMEOUT=300

# Language settings
SUPPORTED_LANGUAGES=de,ja,en
DEFAULT_LANGUAGE=en

# Email (for user management)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-username
SMTP_PASSWORD=your-password

# Monitoring
SENTRY_DSN=

# Commercial features
ENABLE_BILLING=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=DecideAI
NEXT_PUBLIC_APP_VERSION=1.0.0