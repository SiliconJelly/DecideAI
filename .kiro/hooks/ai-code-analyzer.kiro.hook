{
  "enabled": true,
  "name": "👨🏼‍💻 AI Code Quality Analyzer",
  "description": "Monitors source code files for changes and provides AI-powered analysis including code smells detection, design pattern suggestions, and best practices recommendations to improve code quality, readability, maintainability, and performance while maintaining existing functionality.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "ai_employee_decision_system/**/*.py",
      "backend/**/*.py",
      "frontend/src/**/*.tsx",
      "frontend/src/**/*.ts",
      "scripts/**/*.py",
      "tests/**/*.py",
      "*.py"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "As a senior developer expert in LLM and AI models, analyze the modified code files for potential improvements. Start Ollama backend if needed to support the analysis. Focus on:\n\n1. Code smells and anti-patterns\n2. Design pattern opportunities\n3. Best practices compliance\n4. Readability improvements\n5. Maintainability enhancements\n6. Performance optimizations\n7. Security considerations\n\nProvide specific, actionable suggestions while ensuring existing functionality is preserved. Synchronize AI backend operations with the repository state and maintain high confidence scores for project production readiness."
  }
}